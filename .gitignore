# PLUGINS – Drittanbieter (nicht versionieren)
# ============================================
/cms/wp-content/plugins/*
/cms/wp-content/languages/plugins/
/cms/wp-content/languages/themes/

# Agentur-Plugins (werden versioniert)
!/cms/wp-content/plugins/media-lab-agency-core/
!/cms/wp-content/plugins/media-lab-analytics/
!/cms/wp-content/plugins/media-lab-seo/
!/cms/wp-content/plugins/media-lab-woocommerce/

# Janecka Custom Plugin (wird versioniert)
!/cms/wp-content/plugins/fjdf-project/

# ============================================
# THEMES
# ============================================
/cms/wp-content/themes/twenty*/

# Juwelier Janecka Theme (wird versioniert)
!/cms/wp-content/themes/fjdf-theme/

# Build-Artefakte innerhalb des Themes
/cms/wp-content/themes/*/assets/dist/
/cms/wp-content/themes/fjdf-theme/assets/hot

